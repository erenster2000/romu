{
  "name": "@romujs/adapter-levelplay",
  "version": "0.1.1",
  "description": "Romu adapter for Unity LevelPlay (ironSource) playable ads (dapi)",
  "type": "module",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/erenster2000/romu.git",
    "directory": "packages/adapter-levelplay"
  },
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    }
  },
  "files": [
    "dist"
  ],
  "scripts": {
    "build": "tsup src/index.ts --format esm --dts --clean",
    "test": "vitest run --passWithNoTests"
  },
  "dependencies": {
    "@romujs/core": "workspace:*",
    "@romujs/specs": "workspace:*"
  },
  "keywords": [
    "playable-ads",
    "playable",
    "html5-games",
    "advertising",
    "ad-networks",
    "ironsource",
    "levelplay",
    "unity",
    "dapi"
  ],
  "homepage": "https://github.com/erenster2000/romu#readme",
  "bugs": "https://github.com/erenster2000/romu/issues"
}
