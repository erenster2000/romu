{
  "name": "romujs",
  "version": "0.1.1",
  "description": "The open-source framework for building playable ads",
  "type": "module",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/erenster2000/romu.git",
    "directory": "packages/cli"
  },
  "bin": {
    "romu": "./bin/romu.js"
  },
  "exports": {
    "./config": {
      "types": "./dist/config.d.ts",
      "import": "./dist/config.js"
    }
  },
  "files": [
    "bin",
    "dist"
  ],
  "scripts": {
    "build": "tsup src/index.ts src/config.ts --format esm --dts --clean",
    "test": "vitest run --passWithNoTests"
  },
  "dependencies": {
    "@romujs/adapter-applovin": "workspace:*",
    "@romujs/adapter-levelplay": "workspace:*",
    "@romujs/adapter-meta": "workspace:*",
    "@romujs/core": "workspace:*",
    "commander": "^14.0.0"
  },
  "keywords": [
    "playable-ads",
    "playable",
    "html5-games",
    "advertising",
    "ad-networks",
    "cli",
    "build-tool",
    "pixijs",
    "mraid"
  ],
  "homepage": "https://github.com/erenster2000/romu#readme",
  "bugs": "https://github.com/erenster2000/romu/issues"
}
