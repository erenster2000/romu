{
  "name": "romu",
  "version": "0.0.0",
  "description": "The open-source framework for building playable ads",
  "type": "module",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/erenster2000/romu.git",
    "directory": "packages/cli"
  },
  "bin": {
    "romu": "./bin/romu.js"
  },
  "exports": {
    "./config": {
      "types": "./dist/config.d.ts",
      "import": "./dist/config.js"
    }
  },
  "files": [
    "bin",
    "dist"
  ],
  "scripts": {
    "build": "tsup src/index.ts src/config.ts --format esm --dts --clean",
    "test": "vitest run --passWithNoTests"
  },
  "dependencies": {
    "@romu/adapter-applovin": "workspace:*",
    "@romu/adapter-levelplay": "workspace:*",
    "@romu/adapter-meta": "workspace:*",
    "@romu/core": "workspace:*",
    "commander": "^14.0.0"
  }
}
